# Server
APP_PORT=8080
APP_ENV=development

# CORS — frontend origin (only needed in split dev mode; ignored in single-domain mode)
CORS_ORIGIN=http://localhost:5173

# Single-domain: path to the built Vue app (npm run build output). Served by Go at "/".
STATIC_DIR=./frontend/dist

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=admin_system

# JWT
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRE_HOURS=72

# External GDHR API (credentials — fill in before enabling sync)
GDHR_BASE_URL=https://apiatd-gdhr.interior.gov.kh/api/v2/gdhr
GDHR_USER=
GDHR_PASS=
GDHR_KEY=

# Scheduled sync — disabled by default; flip to true when ready to hit the live API
SYNC_ENABLED=false
SYNC_TIMEZONE=Asia/Phnom_Penh
SYNC_WINDOW_START=18:00
SYNC_WINDOW_END=05:00
SYNC_INSTITUTES_INTERVAL=20s
SYNC_STAFFS_INTERVAL=10s
SYNC_HTTP_TIMEOUT=30s

# Redis — durable page cursor so a restart resumes instead of losing progress
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0

# Image proxy — comma-separated allowlist of remote hosts the proxy may fetch from
IMAGE_PROXY_HOSTS=police-gdhr.interior.gov.kh